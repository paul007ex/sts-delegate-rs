{
  "openapi": "3.1.0",
  "info": {
    "title": "sts-delegate-rs",
    "version": "0.0.0",
    "description": "Rust sts-delegate token exchange HTTP contract"
  },
  "paths": {
    "/.well-known/oauth-authorization-server": {
      "get": {
        "summary": "OAuth authorization server metadata",
        "responses": {
          "200": {
            "description": "Authorization server metadata"
          }
        }
      }
    },
    "/jwks": {
      "get": {
        "summary": "Public STS signing JWKS",
        "responses": {
          "200": {
            "description": "Public JWK Set"
          }
        }
      }
    },
    "/.well-known/oauth-protected-resource": {
      "get": {
        "summary": "OAuth protected resource metadata",
        "responses": {
          "200": {
            "description": "Protected resource metadata"
          }
        }
      }
    },
    "/mcp": {
      "get": {
        "summary": "Protected resource challenge",
        "responses": {
          "401": {
            "description": "Bearer challenge with RFC 9728 resource_metadata"
          }
        }
      },
      "post": {
        "summary": "Protected resource challenge",
        "responses": {
          "401": {
            "description": "Bearer challenge with RFC 9728 resource_metadata"
          }
        }
      }
    },
    "/{resource}/mcp": {
      "get": {
        "summary": "Path-bearing protected resource challenge",
        "responses": {
          "401": {
            "description": "Bearer challenge with path-bearing RFC 9728 resource_metadata"
          }
        }
      },
      "post": {
        "summary": "Path-bearing protected resource challenge",
        "responses": {
          "401": {
            "description": "Bearer challenge with path-bearing RFC 9728 resource_metadata"
          }
        }
      }
    },
    "/introspect": {
      "post": {
        "summary": "RFC 7662 token introspection for STS-issued access tokens",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "token",
                  "client_assertion",
                  "client_assertion_type"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "token_type_hint": {
                    "type": "string"
                  },
                  "client_id": {
                    "type": "string"
                  },
                  "client_assertion": {
                    "type": "string"
                  },
                  "client_assertion_type": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token introspection response"
          },
          "400": {
            "description": "OAuth error response"
          },
          "401": {
            "description": "Client authentication failed"
          }
        }
      }
    },
    "/revoke": {
      "post": {
        "summary": "RFC 7009 revocation for STS-issued access tokens",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "token",
                  "client_assertion",
                  "client_assertion_type"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "token_type_hint": {
                    "type": "string"
                  },
                  "client_id": {
                    "type": "string"
                  },
                  "client_assertion": {
                    "type": "string"
                  },
                  "client_assertion_type": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Revocation response"
          },
          "400": {
            "description": "OAuth error response"
          },
          "401": {
            "description": "Client authentication failed"
          }
        }
      }
    },
    "/token": {
      "post": {
        "summary": "OAuth 2.0 token exchange",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "grant_type",
                  "subject_token",
                  "subject_token_type"
                ],
                "properties": {
                  "grant_type": {
                    "type": "string"
                  },
                  "subject_token": {
                    "type": "string"
                  },
                  "subject_token_type": {
                    "type": "string"
                  },
                  "actor_token": {
                    "type": "string"
                  },
                  "actor_token_type": {
                    "type": "string"
                  },
                  "audience": {
                    "type": "string"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "scope": {
                    "type": "string"
                  },
                  "requested_token_type": {
                    "type": "string"
                  },
                  "client_id": {
                    "type": "string"
                  },
                  "client_assertion": {
                    "type": "string"
                  },
                  "client_assertion_type": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token exchange response"
          },
          "400": {
            "description": "OAuth error response"
          },
          "401": {
            "description": "Client authentication failed"
          }
        }
      }
    }
  }
}
