{
  "openapi": "3.1.0",
  "info": {
    "title": "sts-delegate-rs",
    "version": "0.0.0",
    "description": "Rust sts-delegate token exchange HTTP contract"
  },
  "paths": {
    "/.well-known/oauth-authorization-server": {
      "get": {
        "summary": "OAuth authorization server metadata",
        "responses": {
          "200": {
            "description": "Authorization server metadata"
          }
        }
      }
    },
    "/jwks": {
      "get": {
        "summary": "Public STS signing JWKS",
        "responses": {
          "200": {
            "description": "Public JWK Set"
          }
        }
      }
    },
    "/token": {
      "post": {
        "summary": "OAuth 2.0 token exchange",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "grant_type",
                  "subject_token",
                  "subject_token_type"
                ],
                "properties": {
                  "grant_type": {
                    "type": "string"
                  },
                  "subject_token": {
                    "type": "string"
                  },
                  "subject_token_type": {
                    "type": "string"
                  },
                  "actor_token": {
                    "type": "string"
                  },
                  "actor_token_type": {
                    "type": "string"
                  },
                  "audience": {
                    "type": "string"
                  },
                  "resource": {
                    "type": "string"
                  },
                  "scope": {
                    "type": "string"
                  },
                  "requested_token_type": {
                    "type": "string"
                  },
                  "client_id": {
                    "type": "string"
                  },
                  "client_assertion": {
                    "type": "string"
                  },
                  "client_assertion_type": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token exchange response"
          },
          "400": {
            "description": "OAuth error response"
          },
          "401": {
            "description": "Client authentication failed"
          }
        }
      }
    }
  }
}
